# Copy to .env on the server, or paste these keys into Portainer stack "Environment variables".
# Required — Discord Developer Portal + your server

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
WELCOME_CHANNEL_ID=

# Optional — defaults are fine for SignalForge production
DIRECTORY_FEED_URL=https://signalforge.org/directory/hubs.json
HOSTED_HUB_URL=https://p7hub.projectseven.us
SITE_URL=https://signalforge.org
