# Discord bot token — Developer Portal → Bot → Reset Token
DISCORD_TOKEN=

# Application ID — Developer Portal → General Information
DISCORD_CLIENT_ID=

# Server (guild) ID — right-click server → Copy Server ID (Developer Mode on)
DISCORD_GUILD_ID=

# #welcome channel ID — right-click channel → Copy Channel ID
WELCOME_CHANNEL_ID=

# Optional overrides
DIRECTORY_FEED_URL=https://signalforge.org/directory/hubs.json
HOSTED_HUB_URL=https://p7hub.projectseven.us
SITE_URL=https://signalforge.org
